<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ReadyAid" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/teal</item>
        <item name="colorOnPrimary">@color/background_card</item>
        <item name="colorSecondary">@color/amber</item>
        <item name="colorOnSecondary">@color/background_card</item>
        
        <!-- Status bar and navigation bar colors -->
        <item name="android:statusBarColor">@color/background_card</item>
        <item name="android:navigationBarColor">@color/background_card</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

</resources>
